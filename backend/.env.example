DB_HOST=localhost
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=pms_db
JWT_SECRET=your_jwt_secret_key
PORT=5000

# Email (Gmail SMTP — use an App Password)
# Enable 2FA on your Gmail account, then create an App Password:
# https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM="PMS Notifications <your_email@gmail.com>"

# Notification schedule cron expression (default: 8:00 AM daily)
# Format: minute hour day month weekday
NOTIFY_DAILY_CRON=0 8 * * *
